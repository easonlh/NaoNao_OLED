# Wi-Fi 配置
WIFI_SSID=YOUR_WIFI_SSID
WIFI_PASSWORD=YOUR_WIFI_PASSWORD

# OpenWeatherMap (免费 API key: https://openweathermap.org/api)
WEATHER_API_KEY=your_openweathermap_api_key
WEATHER_CITY=Beijing

# MQTT Broker (留空则禁用 MQTT)
MQTT_BROKER=
MQTT_PORT=1883
MQTT_CLIENT_ID=NaoNao_OLED
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_SUBSCRIBE_TOPIC=naonao/cmd
MQTT_PUBLISH_TOPIC=naonao/status

# GitHub 仓库 (格式: owner/repo，留空则禁用)
GITHUB_REPO=

# OTA 无线升级 (留空则禁用)
OTA_HOSTNAME=naonao-oled
OTA_PASSWORD=your_ota_password
